# MicroNature Full-Stack App Environment Configuration

# 💡 MySQL Database Connection Settings
# Update these to match your local running MySQL server
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=micronature

# 💡 Optional: Gemini AI Studio API Key
# If configured, unlocks real-time botanical intelligence diagnoses on the AI Doctor page.
# If left blank, the app gracefully runs with an offline diagnostic simulator.
# GEMINI_API_KEY=AIzaSy...
